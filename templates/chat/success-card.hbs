{{ log 'HEROSYS success-card' this }}
<div class="hero chat-card success-card" data-actor-id="{{actor._id}}" data-item-id="{{item._id}}">
    {{{flavor}}}

    <div class="tags">
        {{#each tags as |tag id|}}
            <span class="tag tag-transparent" title="{{tag.title}}">{{tag.name}} {{tag.value}}</span>
        {{/each}}
    </div>

    {{#if resourceDescription }}
        <hr>

        <div class="card-section">
            {{{resourceDescription}}}
        </div>
    {{/if}}

    <hr>

    <div class="dice-roll">{{{ renderedSuccessRoll }}}</div>
</div>